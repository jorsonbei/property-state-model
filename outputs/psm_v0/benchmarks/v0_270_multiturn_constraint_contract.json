      "family": "correction_priority",
      "messages": [
        {"role": "user", "content": "项目当前版本是什么？"},
        {"role": "assistant", "content": "当前项目是 PSM V0.250。"},
        {"role": "user", "content": "不要沿用上一句，按本地结构化记录更正当前版本。"}
      ],
      "expected_domain": "wuxing_theory",
      "required_all": ["PSM V0.269"],
      "forbidden": ["当前项目是 PSM V0.250"]
    },
    {
      "id": "user_correction_beats_assistant_fact",
      "family": "correction_priority",
      "messages": [
        {"role": "user", "content": "苹果和香蕉哪个通常更软？"},
        {"role": "assistant", "content": "苹果通常比香蕉更软。"},
        {"role": "user", "content": "更正：成熟香蕉通常更软。请只确认更正后的结论。"}
      ],
      "expected_domain": "general",
      "required_all": ["成熟香蕉", "更软"],
      "forbidden": ["苹果通常比香蕉更软"]
    },
    {
      "id": "latest_meeting_time_wins",
      "family": "correction_priority",
      "messages": [
        {"role": "user", "content": "会议暂定下午两点。"},
        {"role": "assistant", "content": "已记录下午两点。"},
        {"role": "user", "content": "更正为下午三点。把最终安排翻译成英文，只给译文。"}
      ],
      "expected_domain": "writing",
      "required_any_groups": [["3", "three"], ["PM", "p.m.", "afternoon"]],
      "forbidden": ["2 PM", "two", "两点", "本地生成模型这次没有返回有效内容"]
    },
    {
      "id": "literal_exclusion_persists_on_shortening",
      "family": "constraint_accumulation",
      "messages": [
        {"role": "user", "content": "结论中不要出现“完全证明”，要保留外部复核边界。"},
        {"role": "assistant", "content": "现有结果仅提供初步支持，仍需外部复核。"},
        {"role": "user", "content": "再压缩成一句话，只给最终结论。"}
      ],
      "expected_domain": "writing",
      "required_any_groups": [["初步", "有限", "尚需"], ["外部复核", "独立验证", "独立复现"]],
      "forbidden": ["完全证明", "本地生成模型这次没有返回有效内容"]
    },
    {
      "id": "format_constraint_persists_on_revision",
      "family": "constraint_accumulation",
      "messages": [
        {"role": "user", "content": "给我三步复习计划，每步写时间。"},
        {"role": "assistant", "content": "1. 20分钟复习公式。\n2. 40分钟做题。\n3. 30分钟整理错题。"},
        {"role": "user", "content": "把第二步改成50分钟，仍然只保留三步。"}
      ],
      "expected_domain": "general",
      "required_all": ["50", "1", "2", "3"],
      "forbidden": ["40分钟", "第四步", "4."]
    },
    {
      "id": "translation_only_constraint_persists",
      "family": "constraint_accumulation",
      "messages": [
        {"role": "user", "content": "把“包裹已安全送达”翻译成英文，只给译文。"},
        {"role": "assistant", "content": "The package was delivered safely."},
        {"role": "user", "content": "把 delivered 改成 arrived，其他约束不变。"}
      ],
      "expected_domain": "writing",
      "required_all": ["arrived", "package"],
      "forbidden": ["delivered", "可以改为", "译文", "本地生成模型这次没有返回有效内容"],
      "max_chars": 100
    }
  ]
}
