    {
      "case_id": "explain_metal_touch",
      "family": "explanation",
      "passed": true,
      "checks": {
        "required_markers_present": true,
        "forbidden_templates_absent": true,
        "length_constraint_met": true,
        "task_not_only_repeated": true,
